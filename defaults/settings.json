{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_TASKS": "true",
    "DISABLE_INSTALLATION_CHECKS": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_COST_WARNINGS": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "FORCE_AUTOUPDATE_PLUGINS": "false",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_CODE_EFFORT_LEVEL": "medium",
    "MAX_MCP_OUTPUT_TOKENS": "15000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "8000"
  },
  "enabledPlugins": {
    "vtsls@kodizm-lsp": true,
    "basedpyright@kodizm-lsp": true,
    "intelephense@kodizm-lsp": true,
    "gopls@kodizm-lsp": true,
    "rust-analyzer@kodizm-lsp": true,
    "ruby-lsp@kodizm-lsp": true,
    "dart-lsp@kodizm-lsp": true,
    "html-lsp@kodizm-lsp": true,
    "css-lsp@kodizm-lsp": true,
    "json-lsp@kodizm-lsp": true,
    "yaml-lsp@kodizm-lsp": true,
    "bash-lsp@kodizm-lsp": true,
    "markdown-lsp@kodizm-lsp": true,
    "tailwind-lsp@kodizm-lsp": true,
    "vue-lsp@kodizm-lsp": true,
    "astro-lsp@kodizm-lsp": true
  },
  "attribution": {
    "commit": "Co-Authored-By: Kodizm <ai@kodizm.com>",
    "pr": "Co-Authored-By: Kodizm <ai@kodizm.com>"
  },
  "voiceEnabled": false,
  "prefersReducedMotion": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "in-process",
  "verbose": false,
  "remoteControlAtStartup": false,
  "defaultMode": "acceptEdits",
  "model": "opus",
  "permissions": {
    "deny": [
      "WebSearch",
      "WebFetch",
      "Agent(Plan)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Web tools blocked — use kodizm MCP tools (web-search, web-fetch) via librarian agent.' >&2; exit 2"
          }
        ]
      },
      {
        "matcher": "Agent(Plan)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Agent(Plan) blocked — Kodizm manages planning via task lifecycle.' >&2; exit 2"
          }
        ]
      }
    ]
  }
}
