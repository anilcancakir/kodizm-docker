{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "env": {
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0",
        "CLAUDE_CODE_ENABLE_TASKS": "true",
        "DISABLE_INSTALLATION_CHECKS": "1",
        "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
        "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
        "DISABLE_BUG_COMMAND": "1",
        "DISABLE_COST_WARNINGS": "1",
        "DISABLE_ERROR_REPORTING": "1",
        "FORCE_AUTOUPDATE_PLUGINS": "true",
        "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
        "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
        "CLAUDE_CODE_EFFORT_LEVEL": "medium"
    },
    "enabledPlugins": {
        "vtsls@kodizm-lsp": false,
        "basedpyright@kodizm-lsp": false,
        "intelephense@kodizm-lsp": false,
        "gopls@kodizm-lsp": false,
        "rust-analyzer@kodizm-lsp": false,
        "ruby-lsp@kodizm-lsp": false,
        "dart-lsp@kodizm-lsp": false,
        "html-lsp@kodizm-lsp": false,
        "css-lsp@kodizm-lsp": false,
        "json-lsp@kodizm-lsp": false,
        "yaml-lsp@kodizm-lsp": false,
        "bash-lsp@kodizm-lsp": false,
        "markdown-lsp@kodizm-lsp": false,
        "tailwind-lsp@kodizm-lsp": false,
        "vue-lsp@kodizm-lsp": false,
        "astro-lsp@kodizm-lsp": false
    },
    "attribution": {
        "commit": "Co-Authored-By: Kodizm <ai@kodizm.com>",
        "pr": "Co-Authored-By: Kodizm <ai@kodizm.com>"
    },
    "model": "opus",
    "voiceEnabled": false,
    "prefersReducedMotion": true,
    "skipDangerousModePermissionPrompt": true,
    "teammateMode": "in-process",
    "verbose": false,
    "remoteControlAtStartup": false,
    "defaultMode": "acceptEdits",
    "permissions": {
        "deny": [
            "EnterPlanMode",
            "ExitPlanMode",
            "WebSearch",
            "WebFetch",
            "Agent(Plan)",
            "Bash(git push*)",
            "Bash(git commit*)",
            "Bash(git checkout*)",
            "Bash(git switch*)",
            "Bash(git rebase*)",
            "Bash(git merge*)",
            "Bash(git reset*)",
            "Bash(git cherry-pick*)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "EnterPlanMode",
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo 'EnterPlanMode blocked \u2014 - Kodizm manages planning via task lifecycle.' >&2; exit 2"
                    }
                ]
            },
            {
                "matcher": "WebSearch|WebFetch",
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo 'Web tools blocked — use kodizm MCP tools (web-search, web-fetch) via librarian agent.' >&2; exit 2"
                    }
                ]
            },
            {
                "matcher": "Agent(Plan)",
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo 'Agent(Plan) blocked — Kodizm manages planning via task lifecycle.' >&2; exit 2"
                    }
                ]
            },
            {
                "matcher": "SendMessage",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node -e \"const i=JSON.parse(process.env.CLAUDE_TOOL_INPUT||'{}'); if(typeof i.message==='string' && !i.summary) { i.summary=i.message.split(' ').slice(0,7).join(' '); console.log(JSON.stringify({updatedInput:i})); } else { console.log(JSON.stringify({})); }\""
                    }
                ]
            }
        ]
    }
}
