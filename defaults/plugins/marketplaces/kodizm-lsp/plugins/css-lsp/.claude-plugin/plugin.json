{
  "name": "css-lsp",
  "description": "CSS/SCSS/LESS language server",
  "author": {
    "name": "Kodizm",
    "url": "https://kodizm.io"
  },
  "lspServers": {
    "css": {
      "command": "vscode-css-language-server",
      "args": [
        "--stdio"
      ],
      "extensionToLanguage": {
        ".css": "css",
        ".scss": "scss",
        ".sass": "sass",
        ".less": "less"
      }
    }
  }
}
