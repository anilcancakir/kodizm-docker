{
  "name": "vue-lsp",
  "description": "Vue.js language server",
  "author": {
    "name": "Kodizm",
    "url": "https://kodizm.io"
  },
  "lspServers": {
    "vue": {
      "command": "vue-language-server",
      "args": [
        "--stdio"
      ],
      "extensionToLanguage": {
        ".vue": "vue"
      },
      "initializationOptions": {
        "typescript": {
          "tsdk": "/opt/nvm/versions/node/v22.16.0/lib/node_modules/typescript/lib"
        }
      }
    }
  }
}
