{
  "name": "basedpyright",
  "description": "Python language server",
  "author": {
    "name": "Kodizm",
    "url": "https://kodizm.io"
  },
  "lspServers": {
    "python": {
      "command": "basedpyright-langserver",
      "args": [
        "--stdio"
      ],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python",
        ".pyw": "python"
      }
    }
  }
}
