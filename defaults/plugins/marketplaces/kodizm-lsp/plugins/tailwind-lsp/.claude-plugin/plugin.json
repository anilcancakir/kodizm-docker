{
  "name": "tailwind-lsp",
  "description": "Tailwind CSS language server",
  "author": {
    "name": "Kodizm",
    "url": "https://kodizm.io"
  },
  "lspServers": {
    "tailwindcss": {
      "command": "tailwindcss-language-server",
      "args": [
        "--stdio"
      ],
      "extensionToLanguage": {
        ".css": "css"
      }
    }
  }
}
