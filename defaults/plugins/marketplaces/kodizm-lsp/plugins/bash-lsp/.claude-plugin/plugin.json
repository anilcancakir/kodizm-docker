{
  "name": "bash-lsp",
  "description": "Bash/Shell language server",
  "author": {
    "name": "Kodizm",
    "url": "https://kodizm.io"
  },
  "lspServers": {
    "bash": {
      "command": "bash-language-server",
      "args": [
        "start"
      ],
      "extensionToLanguage": {
        ".sh": "shellscript",
        ".bash": "shellscript",
        ".zsh": "shellscript"
      }
    }
  }
}
