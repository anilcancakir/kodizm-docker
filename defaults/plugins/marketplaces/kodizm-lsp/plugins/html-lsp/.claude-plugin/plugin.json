{
  "name": "html-lsp",
  "description": "HTML language server",
  "author": {
    "name": "Kodizm",
    "url": "https://kodizm.io"
  },
  "lspServers": {
    "html": {
      "command": "vscode-html-language-server",
      "args": [
        "--stdio"
      ],
      "extensionToLanguage": {
        ".html": "html",
        ".htm": "html"
      }
    }
  }
}
