{
  "name": "dart-lsp",
  "description": "Dart/Flutter language server",
  "author": {
    "name": "Kodizm",
    "url": "https://kodizm.io"
  },
  "lspServers": {
    "dart": {
      "command": "dart",
      "args": [
        "language-server",
        "--protocol=lsp"
      ],
      "extensionToLanguage": {
        ".dart": "dart"
      },
      "startupTimeout": 60000
    }
  }
}
