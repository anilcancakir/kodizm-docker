{
  "name": "json-lsp",
  "description": "JSON language server",
  "author": {
    "name": "Kodizm",
    "url": "https://kodizm.io"
  },
  "lspServers": {
    "json": {
      "command": "vscode-json-language-server",
      "args": [
        "--stdio"
      ],
      "extensionToLanguage": {
        ".json": "json",
        ".jsonc": "jsonc"
      }
    }
  }
}
