{
  "name": "kodizm-lsp",
  "owner": {
    "name": "Kodizm",
    "url": "https://kodizm.io"
  },
  "description": "Kodizm built-in LSP servers for all supported languages",
  "plugins": [
    {
      "name": "vtsls",
      "version": "0.1.0",
      "description": "TypeScript/JavaScript language server (vtsls)",
      "strict": false,
      "lspServers": {
        "typescript": {
          "command": "vtsls",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".ts": "typescript",
            ".tsx": "typescriptreact",
            ".js": "javascript",
            ".jsx": "javascriptreact",
            ".mjs": "javascript",
            ".cjs": "javascript"
          }
        }
      },
      "source": "./plugins/vtsls"
    },
    {
      "name": "basedpyright",
      "version": "0.1.0",
      "description": "Python language server (basedpyright)",
      "strict": false,
      "lspServers": {
        "python": {
          "command": "basedpyright-langserver",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".py": "python",
            ".pyi": "python",
            ".pyw": "python"
          }
        }
      },
      "source": "./plugins/basedpyright"
    },
    {
      "name": "intelephense",
      "version": "0.1.0",
      "description": "PHP language server (intelephense)",
      "strict": false,
      "lspServers": {
        "php": {
          "command": "intelephense",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".php": "php"
          }
        }
      },
      "source": "./plugins/intelephense"
    },
    {
      "name": "gopls",
      "version": "0.1.0",
      "description": "Go language server (gopls)",
      "strict": false,
      "lspServers": {
        "go": {
          "command": "gopls",
          "args": [],
          "extensionToLanguage": {
            ".go": "go"
          }
        }
      },
      "source": "./plugins/gopls"
    },
    {
      "name": "rust-analyzer",
      "version": "0.1.0",
      "description": "Rust language server (rust-analyzer)",
      "strict": false,
      "lspServers": {
        "rust": {
          "command": "rust-analyzer",
          "args": [],
          "extensionToLanguage": {
            ".rs": "rust"
          }
        }
      },
      "source": "./plugins/rust-analyzer"
    },
    {
      "name": "ruby-lsp",
      "version": "0.1.0",
      "description": "Ruby language server (ruby-lsp)",
      "strict": false,
      "lspServers": {
        "ruby": {
          "command": "ruby-lsp",
          "args": [],
          "extensionToLanguage": {
            ".rb": "ruby",
            ".rake": "ruby",
            ".gemspec": "ruby"
          }
        }
      },
      "source": "./plugins/ruby-lsp"
    },
    {
      "name": "dart-lsp",
      "version": "0.1.0",
      "description": "Dart/Flutter language server",
      "strict": false,
      "lspServers": {
        "dart": {
          "command": "dart",
          "args": [
            "language-server",
            "--protocol=lsp"
          ],
          "extensionToLanguage": {
            ".dart": "dart"
          },
          "startupTimeout": 60000
        }
      },
      "source": "./plugins/dart-lsp"
    },
    {
      "name": "html-lsp",
      "version": "0.1.0",
      "description": "HTML language server (vscode-extracted)",
      "strict": false,
      "lspServers": {
        "html": {
          "command": "vscode-html-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".html": "html",
            ".htm": "html"
          }
        }
      },
      "source": "./plugins/html-lsp"
    },
    {
      "name": "css-lsp",
      "version": "0.1.0",
      "description": "CSS/SCSS/LESS language server (vscode-extracted)",
      "strict": false,
      "lspServers": {
        "css": {
          "command": "vscode-css-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".css": "css",
            ".scss": "scss",
            ".sass": "sass",
            ".less": "less"
          }
        }
      },
      "source": "./plugins/css-lsp"
    },
    {
      "name": "json-lsp",
      "version": "0.1.0",
      "description": "JSON language server (vscode-extracted)",
      "strict": false,
      "lspServers": {
        "json": {
          "command": "vscode-json-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".json": "json",
            ".jsonc": "jsonc"
          }
        }
      },
      "source": "./plugins/json-lsp"
    },
    {
      "name": "yaml-lsp",
      "version": "0.1.0",
      "description": "YAML language server (Red Hat)",
      "strict": false,
      "lspServers": {
        "yaml": {
          "command": "yaml-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".yaml": "yaml",
            ".yml": "yaml"
          }
        }
      },
      "source": "./plugins/yaml-lsp"
    },
    {
      "name": "bash-lsp",
      "version": "0.1.0",
      "description": "Bash/Shell language server",
      "strict": false,
      "lspServers": {
        "bash": {
          "command": "bash-language-server",
          "args": [
            "start"
          ],
          "extensionToLanguage": {
            ".sh": "shellscript",
            ".bash": "shellscript",
            ".zsh": "shellscript"
          }
        }
      },
      "source": "./plugins/bash-lsp"
    },
    {
      "name": "markdown-lsp",
      "version": "0.1.0",
      "description": "Markdown language server (marksman)",
      "strict": false,
      "lspServers": {
        "markdown": {
          "command": "marksman",
          "args": [
            "server"
          ],
          "extensionToLanguage": {
            ".md": "markdown",
            ".mdx": "markdown"
          }
        }
      },
      "source": "./plugins/markdown-lsp"
    },
    {
      "name": "tailwind-lsp",
      "version": "0.1.0",
      "description": "Tailwind CSS language server",
      "strict": false,
      "lspServers": {
        "tailwindcss": {
          "command": "tailwindcss-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".css": "css"
          }
        }
      },
      "source": "./plugins/tailwind-lsp"
    },
    {
      "name": "vue-lsp",
      "version": "0.1.0",
      "description": "Vue.js language server (Volar)",
      "strict": false,
      "lspServers": {
        "vue": {
          "command": "vue-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".vue": "vue"
          },
          "initializationOptions": {
            "typescript": {
              "tsdk": "/opt/nvm/versions/node/v22.16.0/lib/node_modules/typescript/lib"
            }
          }
        }
      },
      "source": "./plugins/vue-lsp"
    },
    {
      "name": "astro-lsp",
      "version": "0.1.0",
      "description": "Astro language server",
      "strict": false,
      "lspServers": {
        "astro": {
          "command": "astro-ls",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".astro": "astro"
          },
          "initializationOptions": {
            "typescript": {
              "tsdk": "/opt/nvm/versions/node/v22.16.0/lib/node_modules/typescript/lib"
            }
          }
        }
      },
      "source": "./plugins/astro-lsp"
    }
  ]
}
